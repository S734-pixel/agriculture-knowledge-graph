<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/agriculture-ontology#"
     xml:base="http://example.org/agriculture-ontology"
     xmlns:ex="http://example.org/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:sosa="http://www.w3.org/ns/sosa/"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:swrla="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#">
    <owl:Ontology rdf:about="http://example.org/agriculture-ontology">
        <rdfs:comment>Ontology schema and instance data derived from agriculture_ontology.rdf.</rdfs:comment>
        <rdfs:label>Agriculture Ontology (Crops and Conditions)</rdfs:label>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled -->

    <owl:AnnotationProperty rdf:about="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#closeMatch -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#closeMatch"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#exactMatch -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#exactMatch"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/hasEnvironmentalFactor -->

    <owl:ObjectProperty rdf:about="http://example.org/hasEnvironmentalFactor">
        <rdfs:domain rdf:resource="http://example.org/Crop"/>
        <rdfs:range rdf:resource="http://example.org/EnvironmentalFactor"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <rdfs:label>has environmental factor</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/hasFarmingInput -->

    <owl:ObjectProperty rdf:about="http://example.org/hasFarmingInput">
        <rdfs:domain rdf:resource="http://example.org/Crop"/>
        <rdfs:range rdf:resource="http://example.org/FarmingInput"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <rdfs:label>has farming input</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/hasFarmingOutput -->

    <owl:ObjectProperty rdf:about="http://example.org/hasFarmingOutput">
        <rdfs:domain rdf:resource="http://example.org/Crop"/>
        <rdfs:range rdf:resource="http://example.org/FarmingOutput"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <rdfs:label>has farming output</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/hasSoil -->

    <owl:ObjectProperty rdf:about="http://example.org/hasSoil">
        <rdfs:domain rdf:resource="http://example.org/Crop"/>
        <rdfs:range rdf:resource="http://example.org/Soil"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <rdfs:label>has soil condition</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/hasCropDensity -->

    <owl:DatatypeProperty rdf:about="http://example.org/hasCropDensity">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/sosa/hasSimpleResult"/>
        <rdfs:domain rdf:resource="http://example.org/FarmingOutput"/>
        <rdfs:domain rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:label>has crop density</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/hasFertilizerUsage -->

    <owl:DatatypeProperty rdf:about="http://example.org/hasFertilizerUsage">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/sosa/hasSimpleResult"/>
        <rdfs:domain rdf:resource="http://example.org/FarmingInput"/>
        <rdfs:domain rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:label>has fertilizer usage</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/hasGrowthStage -->

    <owl:DatatypeProperty rdf:about="http://example.org/hasGrowthStage">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/sosa/hasSimpleResult"/>
        <rdfs:domain rdf:resource="http://example.org/FarmingOutput"/>
        <rdfs:domain rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:label>has growth stage</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/hasHumidity -->

    <owl:DatatypeProperty rdf:about="http://example.org/hasHumidity">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/sosa/hasSimpleResult"/>
        <rdfs:domain rdf:resource="http://example.org/EnvironmentalFactor"/>
        <rdfs:domain rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:label>has humidity</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/hasIrrigationFrequency -->

    <owl:DatatypeProperty rdf:about="http://example.org/hasIrrigationFrequency">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/sosa/hasSimpleResult"/>
        <rdfs:domain rdf:resource="http://example.org/FarmingInput"/>
        <rdfs:domain rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:label>has irrigation frequency</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/hasNutrient -->

    <owl:DatatypeProperty rdf:about="http://example.org/hasNutrient">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/sosa/hasSimpleResult"/>
        <rdfs:domain rdf:resource="http://example.org/Crop"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:label>has nutrient value</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/hasRainfall -->

    <owl:DatatypeProperty rdf:about="http://example.org/hasRainfall">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/sosa/hasSimpleResult"/>
        <rdfs:domain rdf:resource="http://example.org/EnvironmentalFactor"/>
        <rdfs:domain rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:label>has rainfall</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/hasSoilMoisture -->

    <owl:DatatypeProperty rdf:about="http://example.org/hasSoilMoisture">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/sosa/hasSimpleResult"/>
        <rdfs:domain rdf:resource="http://example.org/Soil"/>
        <rdfs:domain rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:label>has soil moisture</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/hasSoilType -->

    <owl:DatatypeProperty rdf:about="http://example.org/hasSoilType">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/sosa/hasSimpleResult"/>
        <rdfs:domain rdf:resource="http://example.org/Soil"/>
        <rdfs:domain rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:label>has soil type value</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/hasTemperature -->

    <owl:DatatypeProperty rdf:about="http://example.org/hasTemperature">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/sosa/hasSimpleResult"/>
        <rdfs:domain rdf:resource="http://example.org/EnvironmentalFactor"/>
        <rdfs:domain rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:label>has temperature</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.w3.org/ns/sosa/hasSimpleResult -->

    <owl:DatatypeProperty rdf:about="http://www.w3.org/ns/sosa/hasSimpleResult"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/BeverageCrop -->

    <owl:Class rdf:about="http://example.org/BeverageCrop">
        <rdfs:subClassOf rdf:resource="http://example.org/Crop"/>
        <rdfs:comment>Crops grown for beverage products such as coffee.</rdfs:comment>
        <rdfs:label>Beverage crop</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/CerealCrop -->

    <owl:Class rdf:about="http://example.org/CerealCrop">
        <rdfs:subClassOf rdf:resource="http://example.org/Crop"/>
        <rdfs:comment>Grain crops such as rice and maize.</rdfs:comment>
        <rdfs:label>Cereal crop</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/Crop -->

    <owl:Class rdf:about="http://example.org/Crop">
        <rdfs:label>Crop</rdfs:label>
        <skos:closeMatch rdf:resource="http://aims.fao.org/aos/agrovoc/c_1972"/>
    </owl:Class>
    


    <!-- http://example.org/EnvironmentalFactor -->

    <owl:Class rdf:about="http://example.org/EnvironmentalFactor">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <rdfs:label>EnvironmentalFactor</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/FarmingInput -->

    <owl:Class rdf:about="http://example.org/FarmingInput">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <rdfs:label>FarmingInput</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/FarmingOutput -->

    <owl:Class rdf:about="http://example.org/FarmingOutput">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <rdfs:label>FarmingOutput</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/FiberCrop -->

    <owl:Class rdf:about="http://example.org/FiberCrop">
        <rdfs:subClassOf rdf:resource="http://example.org/Crop"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/sosa/Actuation"/>
        <rdfs:comment>Crops grown primarily for fiber such as cotton and jute.</rdfs:comment>
        <rdfs:label>Fiber crop</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/FruitCrop -->

    <owl:Class rdf:about="http://example.org/FruitCrop">
        <rdfs:subClassOf rdf:resource="http://example.org/Crop"/>
        <rdfs:comment>Crops producing edible fruits.</rdfs:comment>
        <rdfs:label>Fruit crop</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/LegumeCrop -->

    <owl:Class rdf:about="http://example.org/LegumeCrop">
        <rdfs:subClassOf rdf:resource="http://example.org/Crop"/>
        <rdfs:comment>Leguminous pulse crops such as chickpea and beans.</rdfs:comment>
        <rdfs:label>Legume (pulse) crop</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/Nutrient -->

    <owl:Class rdf:about="http://example.org/Nutrient">
        <rdfs:label>Nutrient</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/Soil -->

    <owl:Class rdf:about="http://example.org/Soil">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <rdfs:label>SoilCondition</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/agriculture-ontology#ex:ColdStressRisk -->

    <owl:Class rdf:about="http://example.org/agriculture-ontology#ex:ColdStressRisk"/>
    


    <!-- http://example.org/agriculture-ontology#ex:DiseasePreventionRecommendation -->

    <owl:Class rdf:about="http://example.org/agriculture-ontology#ex:DiseasePreventionRecommendation"/>
    


    <!-- http://example.org/agriculture-ontology#ex:DiseaseRisk -->

    <owl:Class rdf:about="http://example.org/agriculture-ontology#ex:DiseaseRisk"/>
    


    <!-- http://example.org/agriculture-ontology#ex:DroughtRisk -->

    <owl:Class rdf:about="http://example.org/agriculture-ontology#ex:DroughtRisk"/>
    


    <!-- http://example.org/agriculture-ontology#ex:ExcessRainRisk -->

    <owl:Class rdf:about="http://example.org/agriculture-ontology#ex:ExcessRainRisk"/>
    


    <!-- http://example.org/agriculture-ontology#ex:HeatStressRisk -->

    <owl:Class rdf:about="http://example.org/agriculture-ontology#ex:HeatStressRisk"/>
    


    <!-- http://example.org/agriculture-ontology#ex:HighCropDensity -->

    <owl:Class rdf:about="http://example.org/agriculture-ontology#ex:HighCropDensity"/>
    


    <!-- http://example.org/agriculture-ontology#ex:HighFertilizerUse -->

    <owl:Class rdf:about="http://example.org/agriculture-ontology#ex:HighFertilizerUse"/>
    


    <!-- http://example.org/agriculture-ontology#ex:HighHumidityRisk -->

    <owl:Class rdf:about="http://example.org/agriculture-ontology#ex:HighHumidityRisk"/>
    


    <!-- http://example.org/agriculture-ontology#ex:LowCropDensity -->

    <owl:Class rdf:about="http://example.org/agriculture-ontology#ex:LowCropDensity"/>
    


    <!-- http://example.org/agriculture-ontology#ex:LowIrrigation -->

    <owl:Class rdf:about="http://example.org/agriculture-ontology#ex:LowIrrigation"/>
    


    <!-- http://example.org/agriculture-ontology#ex:LowSoilMoistureRisk -->

    <owl:Class rdf:about="http://example.org/agriculture-ontology#ex:LowSoilMoistureRisk"/>
    


    <!-- http://example.org/agriculture-ontology#ex:OverallStressRisk -->

    <owl:Class rdf:about="http://example.org/agriculture-ontology#ex:OverallStressRisk"/>
    


    <!-- http://example.org/agriculture-ontology#ex:WaterRisk -->

    <owl:Class rdf:about="http://example.org/agriculture-ontology#ex:WaterRisk"/>
    


    <!-- http://example.org/agriculture-ontology#ex:WaterloggingRisk -->

    <owl:Class rdf:about="http://example.org/agriculture-ontology#ex:WaterloggingRisk"/>
    


    <!-- http://example.org/ex:DroughtMitigationRecommendation -->

    <owl:Class rdf:about="http://example.org/ex:DroughtMitigationRecommendation"/>
    


    <!-- http://example.org/ex:HeatMitigationRecommendation -->

    <owl:Class rdf:about="http://example.org/ex:HeatMitigationRecommendation"/>
    


    <!-- http://example.org/ex:ImproveDrainageRecommendation -->

    <owl:Class rdf:about="http://example.org/ex:ImproveDrainageRecommendation"/>
    


    <!-- http://example.org/ex:IncreaseIrrigationRecommendation -->

    <owl:Class rdf:about="http://example.org/ex:IncreaseIrrigationRecommendation"/>
    


    <!-- http://example.org/ex:ReduceFertilizerRecommendation -->

    <owl:Class rdf:about="http://example.org/ex:ReduceFertilizerRecommendation"/>
    


    <!-- http://www.w3.org/ns/sosa/Actuation -->

    <owl:Class rdf:about="http://www.w3.org/ns/sosa/Actuation"/>
    


    <!-- http://www.w3.org/ns/sosa/Observation -->

    <owl:Class rdf:about="http://www.w3.org/ns/sosa/Observation"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/apple -->

    <owl:NamedIndividual rdf:about="http://example.org/apple">
        <rdf:type rdf:resource="http://example.org/Crop"/>
        <rdf:type rdf:resource="http://example.org/FruitCrop"/>
        <rdf:type rdf:resource="http://example.org/agriculture-ontology#ex:HighHumidityRisk"/>
        <rdf:type rdf:resource="http://example.org/agriculture-ontology#ex:LowCropDensity"/>
        <ex:hasEnvironmentalFactor rdf:resource="http://example.org/humidity_apple"/>
        <ex:hasEnvironmentalFactor rdf:resource="http://example.org/rainfall_apple"/>
        <ex:hasEnvironmentalFactor rdf:resource="http://example.org/temp_apple"/>
        <ex:hasFarmingInput rdf:resource="http://example.org/fertilizer_apple"/>
        <ex:hasFarmingInput rdf:resource="http://example.org/irrigation_apple"/>
        <ex:hasFarmingOutput rdf:resource="http://example.org/crop_density_apple"/>
        <ex:hasFarmingOutput rdf:resource="http://example.org/growth_stage_apple"/>
        <ex:hasSoil rdf:resource="http://example.org/soil_moisture_apple"/>
        <ex:hasSoil rdf:resource="http://example.org/soil_type_apple"/>
        <ex:hasNutrient rdf:datatype="http://www.w3.org/2001/XMLSchema#float">134.22</ex:hasNutrient>
        <ex:hasNutrient rdf:datatype="http://www.w3.org/2001/XMLSchema#float">199.89</ex:hasNutrient>
        <ex:hasNutrient rdf:datatype="http://www.w3.org/2001/XMLSchema#float">20.8</ex:hasNutrient>
        <sosa:hasSimpleResult rdf:datatype="http://www.w3.org/2001/XMLSchema#float">134.22</sosa:hasSimpleResult>
        <sosa:hasSimpleResult rdf:datatype="http://www.w3.org/2001/XMLSchema#float">199.89</sosa:hasSimpleResult>
        <sosa:hasSimpleResult rdf:datatype="http://www.w3.org/2001/XMLSchema#float">20.8</sosa:hasSimpleResult>
        <skos:exactMatch rdf:resource="http://aims.fao.org/aos/agrovoc/c_541"/>
    </owl:NamedIndividual>
    


    <!-- http://example.org/banana -->

    <owl:NamedIndividual rdf:about="http://example.org/banana">
        <rdf:type rdf:resource="http://example.org/Crop"/>
        <rdf:type rdf:resource="http://example.org/FruitCrop"/>
        <rdf:type rdf:resource="http://example.org/agriculture-ontology#ex:HighHumidityRisk"/>
        <rdf:type rdf:resource="http://example.org/agriculture-ontology#ex:LowCropDensity"/>
        <ex:hasEnvironmentalFactor rdf:resource="http://example.org/humidity_banana"/>
        <ex:hasEnvironmentalFactor rdf:resource="http://example.org/rainfall_banana"/>
        <ex:hasEnvironmentalFactor rdf:resource="http://example.org/temp_banana"/>
        <ex:hasFarmingInput rdf:resource="http://example.org/fertilizer_banana"/>
        <ex:hasFarmingInput rdf:resource="http://example.org/irrigation_banana"/>
        <ex:hasFarmingOutput rdf:resource="http://example.org/crop_density_banana"/>
        <ex:hasFarmingOutput rdf:resource="http://example.org/growth_stage_banana"/>
        <ex:hasSoil rdf:resource="http://example.org/soil_moisture_banana"/>
        <ex:hasSoil rdf:resource="http://example.org/soil_type_banana"/>
        <ex:hasNutrient rdf:datatype="http://www.w3.org/2001/XMLSchema#float">100.23</ex:hasNutrient>
        <ex:hasNutrient rdf:datatype="http://www.w3.org/2001/XMLSchema#float">50.05</ex:hasNutrient>
        <ex:hasNutrient rdf:datatype="http://www.w3.org/2001/XMLSchema#float">82.01</ex:hasNutrient>
        <sosa:hasSimpleResult rdf:datatype="http://www.w3.org/2001/XMLSchema#float">100.23</sosa:hasSimpleResult>
        <sosa:hasSimpleResult rdf:datatype="http://www.w3.org/2001/XMLSchema#float">50.05</sosa:hasSimpleResult>
        <sosa:hasSimpleResult rdf:datatype="http://www.w3.org/2001/XMLSchema#float">82.01</sosa:hasSimpleResult>
        <skos:exactMatch rdf:resource="http://aims.fao.org/aos/agrovoc/c_806"/>
    </owl:NamedIndividual>
    


    <!-- http://example.org/blackgram -->

    <owl:NamedIndividual rdf:about="http://example.org/blackgram">
        <rdf:type rdf:resource="http://example.org/Crop"/>
        <rdf:type rdf:resource="http://example.org/LegumeCrop"/>
        <rdf:type rdf:resource="http://example.org/agriculture-ontology#ex:LowCropDensity"/>
        <ex:hasEnvironmentalFactor rdf:resource="http://example.org/humidity_blackgram"/>
        <ex:hasEnvironmentalFactor rdf:resource="http://example.org/rainfall_blackgram"/>
        <ex:hasEnvironmentalFactor rdf:resource="http://example.org/temp_blackgram"/>
        <ex:hasFarmingInput rdf:resource="http://example.org/fertilizer_blackgram"/>
        <ex:hasFarmingInput rdf:resource="http://example.org/irrigation_blackgram"/>
        <ex:hasFarmingOutput rdf:resource="http://example.org/crop_density_blackgram"/>
        <ex:hasFarmingOutput rdf:resource="http://example.org/growth_stage_blackgram"/>
        <ex:hasSoil rdf:resource="http://example.org/soil_moisture_blackgram"/>
        <ex:hasSoil rdf:resource="http://example.org/soil_type_blackgram"/>
        <ex:hasNutrient rdf:datatype="http://www.w3.org/2001/XMLSchema#float">19.24</ex:hasNutrient>
        <ex:hasNutrient rdf:datatype="http://www.w3.org/2001/XMLSchema#float">40.02</ex:hasNutrient>
        <ex:hasNutrient rdf:datatype="http://www.w3.org/2001/XMLSchema#float">67.47</ex:hasNutrient>
        <sosa:hasSimpleResult rdf:datatype="http://www.w3.org/2001/XMLSchema#float">19.24</sosa:hasSimpleResult>
        <sosa:hasSimpleResult rdf:datatype="http://www.w3.org/2001/XMLSchema#float">40.02</sosa:hasSimpleResult>
        <sosa:hasSimpleResult rdf:datatype="http://www.w3.org/2001/XMLSchema#float">67.47</sosa:hasSimpleResult>
        <skos:exactMatch rdf:resource="http://aims.fao.org/aos/agrovoc/c_8089"/>
    </owl:NamedIndividual>
    


    <!-- http://example.org/chickpea -->

    <owl:NamedIndividual rdf:about="http://example.org/chickpea">
        <rdf:type rdf:resource="http://example.org/Crop"/>
        <rdf:type rdf:resource="http://example.org/LegumeCrop"/>
        <rdf:type rdf:resource="http://example.org/agriculture-ontology#ex:LowCropDensity"/>
        <ex:hasEnvironmentalFactor rdf:resource="http://example.org/humidity_chickpea"/>
        <ex:hasEnvironmentalFactor rdf:resource="http://example.org/rainfall_chickpea"/>
        <ex:hasEnvironmentalFactor rdf:resource="http://example.org/temp_chickpea"/>
        <ex:hasFarmingInput rdf:resource="http://example.org/fertilizer_chickpea"/>
        <ex:hasFarmingInput rdf:resource="http://example.org/irrigation_chickpea"/>
        <ex:hasFarmingOutput rdf:resource="http://example.org/crop_density_chickpea"/>
        <ex:hasFarmingOutput rdf:resource="http://example.org/growth_stage_chickpea"/>
        <ex:hasSoil rdf:resource="http://example.org/soil_moisture_chickpea"/>
